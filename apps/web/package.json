    "@toolings/tailwind-config": "workspace:*",
    "@toolings/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "eslint": "catalog:",
    "eslint-config-next": "16.2.9",
    "jiti": "^2.7.0",
    "prettier": "catalog:",
