{
  "name": "stia",
  "private": true,
  "engines": {
    "node": "^26.0.0",
    "pnpm": "^11.9.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @packages/auth auth-generate",
    "db:generate": "turbo -F @packages/db db-generate",
    "db:migrate": "turbo -F @packages/db db-migrate",
    "db:push": "turbo -F @packages/db db-push",
    "db:studio": "turbo -F @packages/db db-studio",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @packages/web...",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "doctor:mobile": "pnpm --filter @apps/mobile exec npx expo-doctor",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prepare": "husky"
  },
  "devDependencies": {
    "@toolings/prettier-config": "workspace:*",
    "@types/node": "catalog:",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "prettier": "catalog:",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "prettier": "@toolings/prettier-config"
}
