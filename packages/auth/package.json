{
  "name": "@packages/auth",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./middleware": "./src/middleware.ts",
    "./client": "./src/client.ts",
    "./env": "./env.ts"
  },
  "license": "MIT",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "auth-generate": "dotenv -e ../../.env -- pnpm dlx @better-auth/cli generate --config script/auth-cli.ts --output ../db/src/schema/auth.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/expo": "catalog:",
    "@packages/db": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-auth/cli": "catalog:",
    "@toolings/eslint-config": "workspace:*",
    "@toolings/prettier-config": "workspace:*",
    "@toolings/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@toolings/prettier-config"
}
